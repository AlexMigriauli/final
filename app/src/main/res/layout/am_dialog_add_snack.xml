<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/amEtSnackName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/am_snack_name_hint"
        android:inputType="text" />

    <EditText
        android:id="@+id/amEtSnackPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/am_snack_price_hint"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/amEtSnackDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/am_snack_desc_hint"
        android:inputType="textMultiLine" />

</LinearLayout>
